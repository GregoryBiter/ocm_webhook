{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-module" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-bolt"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" id="form-module" class="form-horizontal">
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="{{ module_code }}_status" id="input-status" class="form-control">
                {% if attribute(_context, module_code ~ '_status') %}
                  <option value="1" selected="selected">{{ text_enabled }}</option>
                  <option value="0">{{ text_disabled }}</option>
                {% else %}
                  <option value="1">{{ text_enabled }}</option>
                  <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
            </div>
          </div>

          <hr>

          <div class="form-group">
            <label class="col-sm-2 control-label">{{ entry_rules }}</label>
            <div class="col-sm-10">
              <div class="help-block">{{ help_rules }}</div>
              <div class="table-responsive">
                <table class="table table-bordered table-hover" id="rules-table">
                  <thead>
                    <tr>
                      <th style="width: 28%;">{{ entry_event }}</th>
                      <th style="width: 42%;">{{ entry_url }}</th>
                      <th style="width: 22%;">{{ entry_auth }}</th>
                      <th style="width: 7%;">{{ entry_sort_order }}</th>
                      <th style="width: 1px;"></th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for rule in attribute(_context, module_code ~ '_rules') %}
                      <tr>
                        <td>
                          <input type="hidden" name="{{ module_code }}_rules[{{ loop.index0 }}][code]" value="{{ rule.code }}">
                          <input type="text" name="{{ module_code }}_rules[{{ loop.index0 }}][event]" value="{{ rule.event }}" class="form-control" placeholder="{{ entry_event }}">
                          <div class="help-block">{{ help_event }}</div>
                        </td>
                        <td>
                          <input type="text" name="{{ module_code }}_rules[{{ loop.index0 }}][url]" value="{{ rule.url }}" class="form-control" placeholder="https://example.com/webhook">
                          <div class="help-block">{{ help_url }}</div>
                        </td>
                        <td>
                          <label class="control-label" for="input-auth-type-{{ loop.index0 }}" style="display:block; text-align:left;">{{ entry_auth_type }}</label>
                          <select name="{{ module_code }}_rules[{{ loop.index0 }}][auth_type]" id="input-auth-type-{{ loop.index0 }}" class="form-control" data-auth-toggle>
                            {% set rule_auth_type = rule.auth_type|default('none') %}
                            <option value="none"{% if rule_auth_type == 'none' %} selected="selected"{% endif %}>{{ text_auth_none }}</option>
                            <option value="query"{% if rule_auth_type == 'query' %} selected="selected"{% endif %}>{{ text_auth_query }}</option>
                            <option value="bearer"{% if rule_auth_type == 'bearer' %} selected="selected"{% endif %}>{{ text_auth_bearer }}</option>
                            <option value="header"{% if rule_auth_type == 'header' %} selected="selected"{% endif %}>{{ text_auth_header }}</option>
                            <option value="basic"{% if rule_auth_type == 'basic' %} selected="selected"{% endif %}>{{ text_auth_basic }}</option>
                            <option value="hmac"{% if rule_auth_type == 'hmac' %} selected="selected"{% endif %}>{{ text_auth_hmac }}</option>
                          </select>
                          <div class="help-block">{{ help_auth }}</div>

                          <div class="auth-token-fields" data-auth-fields="token" style="margin-top: 10px;{% if rule_auth_type not in ['query', 'bearer', 'header', 'hmac'] %} display:none;{% endif %}">
                            <label class="control-label" for="input-auth-token-{{ loop.index0 }}" style="display:block; text-align:left;">{{ entry_auth_token }}</label>
                            <div class="input-group">
                              <input type="text" name="{{ module_code }}_rules[{{ loop.index0 }}][auth_token]" id="input-auth-token-{{ loop.index0 }}" value="{{ rule.auth_token|default('') }}" class="form-control" placeholder="sk_...">
                              <span class="input-group-btn">
                                <button type="button" class="btn btn-default btn-generate-token" data-target="input-auth-token-{{ loop.index0 }}">{{ button_generate_token }}</button>
                              </span>
                            </div>
                            <div class="help-block">{{ help_auth_token }}</div>
                          </div>

                          <div class="auth-basic-fields" data-auth-fields="basic" style="margin-top: 10px;{% if rule_auth_type != 'basic' %} display:none;{% endif %}">
                            <label class="control-label" for="input-auth-username-{{ loop.index0 }}" style="display:block; text-align:left;">{{ entry_auth_username }}</label>
                            <input type="text" name="{{ module_code }}_rules[{{ loop.index0 }}][auth_username]" id="input-auth-username-{{ loop.index0 }}" value="{{ rule.auth_username|default('') }}" class="form-control" autocomplete="off">

                            <label class="control-label" for="input-auth-password-{{ loop.index0 }}" style="display:block; text-align:left; margin-top: 8px;">{{ entry_auth_password }}</label>
                            <input type="password" name="{{ module_code }}_rules[{{ loop.index0 }}][auth_password]" id="input-auth-password-{{ loop.index0 }}" value="{{ rule.auth_password|default('') }}" class="form-control" autocomplete="new-password">
                            <div class="help-block">{{ help_auth_basic }}</div>
                          </div>
                        </td>
                        <td>
                          <input type="number" name="{{ module_code }}_rules[{{ loop.index0 }}][sort_order]" value="{{ rule.sort_order }}" class="form-control" min="0" step="1">
                          <div class="help-block">{{ help_sort_order }}</div>
                        </td>
                        <td class="text-center">
                          <button type="button" class="btn btn-danger btn-remove-rule"><i class="fa fa-minus-circle"></i> {{ button_remove }}</button>
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                  <tfoot>
                    <tr>
                      <td colspan="4">
                        <button type="button" id="button-add-rule" class="btn btn-primary"><i class="fa fa-plus-circle"></i> {{ button_add_rule }}</button>
                      </td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script type="text/template" id="rule-row-template">
  <tr>
    <td>
      <input type="hidden" name="{{ module_code }}_rules[__index__][code]" value="__code__">
      <input type="text" name="{{ module_code }}_rules[__index__][event]" value="" class="form-control" placeholder="{{ entry_event }}">
      <div class="help-block">{{ help_event }}</div>
    </td>
    <td>
      <input type="text" name="{{ module_code }}_rules[__index__][url]" value="" class="form-control" placeholder="https://example.com/webhook">
      <div class="help-block">{{ help_url }}</div>
    </td>
    <td>
      <label class="control-label" for="input-auth-type-__index__" style="display:block; text-align:left;">{{ entry_auth_type }}</label>
      <select name="{{ module_code }}_rules[__index__][auth_type]" id="input-auth-type-__index__" class="form-control" data-auth-toggle>
        <option value="none" selected="selected">{{ text_auth_none }}</option>
        <option value="query">{{ text_auth_query }}</option>
        <option value="bearer">{{ text_auth_bearer }}</option>
        <option value="header">{{ text_auth_header }}</option>
        <option value="basic">{{ text_auth_basic }}</option>
        <option value="hmac">{{ text_auth_hmac }}</option>
      </select>
      <div class="help-block">{{ help_auth }}</div>

      <div class="auth-token-fields" data-auth-fields="token" style="margin-top: 10px; display:none;">
        <label class="control-label" for="input-auth-token-__index__" style="display:block; text-align:left;">{{ entry_auth_token }}</label>
        <div class="input-group">
          <input type="text" name="{{ module_code }}_rules[__index__][auth_token]" id="input-auth-token-__index__" value="" class="form-control" placeholder="sk_...">
          <span class="input-group-btn">
            <button type="button" class="btn btn-default btn-generate-token" data-target="input-auth-token-__index__">{{ button_generate_token }}</button>
          </span>
        </div>
        <div class="help-block">{{ help_auth_token }}</div>
      </div>

      <div class="auth-basic-fields" data-auth-fields="basic" style="margin-top: 10px; display:none;">
        <label class="control-label" for="input-auth-username-__index__" style="display:block; text-align:left;">{{ entry_auth_username }}</label>
        <input type="text" name="{{ module_code }}_rules[__index__][auth_username]" id="input-auth-username-__index__" value="" class="form-control" autocomplete="off">

        <label class="control-label" for="input-auth-password-__index__" style="display:block; text-align:left; margin-top: 8px;">{{ entry_auth_password }}</label>
        <input type="password" name="{{ module_code }}_rules[__index__][auth_password]" id="input-auth-password-__index__" value="" class="form-control" autocomplete="new-password">
        <div class="help-block">{{ help_auth_basic }}</div>
      </div>
    </td>
    <td class="text-center">
      <input type="number" name="{{ module_code }}_rules[__index__][sort_order]" value="1000" class="form-control" min="0" step="1">
      <div class="help-block">{{ help_sort_order }}</div>
    </td>
    <td class="text-center">
      <button type="button" class="btn btn-danger btn-remove-rule"><i class="fa fa-minus-circle"></i> {{ button_remove }}</button>
    </td>
  </tr>
</script>

<script>
(function () {
  var tableBody = document.querySelector('#rules-table tbody');
  var addButton = document.getElementById('button-add-rule');
  var template = document.getElementById('rule-row-template').innerHTML;

  function uniqueToken() {
    return 'ocm_webhook_' + Math.random().toString(36).slice(2, 10) + Date.now().toString(36);
  }

  function generateSecret(length) {
    var alphabet = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_';
    var size = length || 32;
    var result = '';

    if (window.crypto && window.crypto.getRandomValues) {
      var bytes = new Uint8Array(size);
      window.crypto.getRandomValues(bytes);

      for (var i = 0; i < bytes.length; i++) {
        result += alphabet.charAt(bytes[i] % alphabet.length);
      }

      return result;
    }

    for (var j = 0; j < size; j++) {
      result += alphabet.charAt(Math.floor(Math.random() * alphabet.length));
    }

    return result;
  }

  function toggleAuthFields(select) {
    var row = select.closest('tr');
    if (!row) {
      return;
    }

    var type = select.value;
    var tokenFields = row.querySelector('[data-auth-fields="token"]');
    var basicFields = row.querySelector('[data-auth-fields="basic"]');

    if (tokenFields) {
      tokenFields.style.display = (type === 'query' || type === 'bearer' || type === 'header' || type === 'hmac') ? '' : 'none';
    }

    if (basicFields) {
      basicFields.style.display = (type === 'basic') ? '' : 'none';
    }
  }

  function bindRemove(button) {
    button.addEventListener('click', function () {
      var row = this.closest('tr');
      if (row) {
        row.parentNode.removeChild(row);
      }
    });
  }

  function bindAuth(select) {
    select.addEventListener('change', function () {
      toggleAuthFields(this);
    });

    toggleAuthFields(select);
  }

  function bindTokenButtons(row) {
    Array.prototype.forEach.call(row.querySelectorAll('.btn-generate-token'), function (button) {
      button.addEventListener('click', function () {
        var target = document.getElementById(this.getAttribute('data-target'));
        if (target) {
          target.value = generateSecret(40);
          target.focus();
          target.select();
        }
      });
    });
  }

  function addRow() {
    var index = uniqueToken();
    var rowHtml = template
      .replace(/__index__/g, index)
      .replace(/__code__/g, uniqueToken());

    var wrapper = document.createElement('tbody');
    wrapper.innerHTML = rowHtml.trim();
    var row = wrapper.firstElementChild;
    tableBody.appendChild(row);
    bindRemove(row.querySelector('.btn-remove-rule'));
    bindTokenButtons(row);
    bindAuth(row.querySelector('[data-auth-toggle]'));
  }

  Array.prototype.forEach.call(document.querySelectorAll('.btn-remove-rule'), bindRemove);
  Array.prototype.forEach.call(document.querySelectorAll('[data-auth-toggle]'), bindAuth);
  Array.prototype.forEach.call(document.querySelectorAll('.btn-generate-token'), function (button) {
    button.addEventListener('click', function () {
      var target = document.getElementById(this.getAttribute('data-target'));
      if (target) {
        target.value = generateSecret(40);
        target.focus();
        target.select();
      }
    });
  });

  addButton.addEventListener('click', addRow);
})();
</script>

{{ footer }}
